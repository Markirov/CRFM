  {
    "tableName": "FORCE_RANDOM_BACKGROUND_TABLE",
    "data": [
      {
        "3D6_Result": 3,
        "Background": "Atrocity. The Force committed a mass murder of innocents. –50 Reputation."
      },
      {
        "3D6_Result": 4,
        "Background": "War criminals. The Force committed a serious crime, accidentally killing many civilians; committed rape, or indulged in kidnapping. –25 Reputation."
      },
      {
        "3D6_Result": 5,
        "Background": "Contract breach. The Force violated a contract (if mercenary) or orders (if government). –25 Reputation. Ignore this result if a pirate Force."
      },
      {
        "3D6_Result": 6,
        "Background": "Textbook warriors. The Force got into a rut, favoring fighting in certain conditions over others. The Force now suffers a –1 Initiative in a specific terrain type (e.g., woods)."
      },
      {
        "3D6_Result": 7,
        "Background": "Poor discipline. The Force launched an unauthorized raid or indulged in looting. –5 Reputation."
      },
      {
        "3D6_Result": 8,
        "Background": "Debt. The Force loses any leftover funds from Force creation and starts in debt at an amount equal to 1D6 times its peacetime monthly operating cost. -10 Reputation."
      },
      {
        "3D6_Result": "9-12",
        "Background": "The Force had a quiet year in a garrison or cadre mission."
      },
      {
        "3D6_Result": 13,
        "Background": "Profitable year. After completing some missions successfully, the Force’s bank account is in the black. Delete any debt from Force creation and give the Force a bonus equal to 1D6 times its monthly operating cost."
      },
      {
        "3D6_Result": 14,
        "Background": "Out-of-the-box thinkers. After repeated campaigns in unusual terrain, the Force gains a +1 Initiative bonus in a specific terrain type."
      },
      {
        "3D6_Result": 15,
        "Background": "Hard training and experience pay off. The Force gains a +1 Piloting/Driving Skill bonus in a specific terrain type."
      },
      {
        "3D6_Result": 16,
        "Background": "The Force has a string of successful missions and gains 1D6 x 5 Reputation points."
      },
      {
        "3D6_Result": 17,
        "Background": "The Force has a string of successful missions against one foe, learning best how to kill them dead. The Force has a +1 Gunnery Skill bonus against that faction."
      },
      {
        "3D6_Result": 18,
        "Background": "They came, they saw, they conquered. The Force is almost unbeaten after years of hard combat, gaining 2D6 x 5 Reputation points."
      }
    ]
  },
