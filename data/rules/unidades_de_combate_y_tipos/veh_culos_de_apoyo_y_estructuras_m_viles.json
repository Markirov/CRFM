    "table_name": "Descripciones de Modificaciones de Chasis",
    "records": [
      {
        "Modificación": "Anfibio (Amphibious)",
        "Descripción/Características": "Puede atravesar o aterrizar en agua de cualquier profundidad (la unidad se considera a flote en la superficie del agua)."
      },
      {
        "Modificación": "Blindado (Armored)",
        "Descripción/Características": "Puede montar tipos de blindaje más pesados (marcados con un asterisco en la Tabla de Blindaje de Vehículos de Apoyo)."
      },
      {
        "Modificación": "Bicicleta (Bicycle)",
        "Descripción/Características": "Puede entrar en terreno de Bosque Ligero, si de otro modo estuviera restringido."
      },
      {
        "Modificación": "Descapotable (Convertible)",
        "Descripción/Características": "No puede montar una torreta; la unidad recibe un resultado de Tripulación Muerta si es impactada en una localización de Torreta mientras la capota está abierta."
      },
      {
        "Modificación": "Buggy de Dunas (Dune Buggy)",
        "Descripción/Características": "Opera normalmente solo en Arena; cuando no está en Arena: -1 PM de Crucero, y la unidad no puede usar PM de Flanco."
      },
      {
        "Modificación": "Sellado Ambiental (Environmental Sealing)",
        "Descripción/Características": "Las unidades con motores de Fisión, Fusión y Eléctricos pueden operar normalmente en vacío o bajo el agua a menos que se rompa el sello."
      },
      {
        "Modificación": "Hidroala (Hydrofoil)",
        "Descripción/Características": "Puede operar como un hidroala; multiplica el PM de Crucero base por 1.25 (redondeo normal, redondeando .5 hacia arriba)."
      },
      {
        "Modificación": "Monociclo (Monocycle)",
        "Descripción/Características": "Puede entrar en terreno de Bosque Ligero, si de otro modo estuviera restringido."
      },
      {
        "Modificación": "Todoterreno (Off-Road)",
        "Descripción/Características": "Opera normalmente sobre y fuera de terreno Pavimentado; la unidad sigue considerándose inmóvil si entra en terreno prohibido."
      },
      {
        "Modificación": "Omni",
        "Descripción/Características": "Puede construirse como un OmniVehículo (pero no puede usar reglas de Infantería Mecanizada)."
      },
      {
        "Modificación": "Hélice (Prop)",
        "Descripción/Características": "No puede operar por encima de la fila atmosférica 1; solo se mueve 1 hexágono por turno en el mapa de gran altitud; Entra Fuera de Control a Velocidad 8+."
      },
      {
        "Modificación": "Moto de Nieve (Snowmobile)",
        "Descripción/Características": "Opera normalmente solo en Nieve/Hielo; cuando no está en Nieve o Hielo: -1 PM de Crucero, y la unidad no puede usar PM de Flanco."
      },
      {
        "Modificación": "STOL",
        "Descripción/Características": "Puede aterrizar y despegar con solo 300 metros (10 hexágonos) de pista."
      },
      {
        "Modificación": "Sumergible (Submersible)",
        "Descripción/Características": "Puede operar como un submarino (no puede usar la modificación de hidroala, si está equipado, cuando está sumergido)."
      },
      {
        "Modificación": "Tractor (Ruedas/Oruga)",
        "Descripción/Características": "Puede remolcar otras unidades terrestres sobre terreno no acuático (hasta el peso de la unidad remolcadora)."
      },
      {
        "Modificación": "Tractor (Naval)",
        "Descripción/Características": "Puede remolcar otras unidades navales sobre agua (hasta 5 veces el peso de la unidad remolcadora)."
      },
      {
        "Modificación": "Remolque (Trailer)",
        "Descripción/Características": "No se requiere motor (la unidad puede ser remolcada por un Tractor adecuado); no se requiere para unidades navales."
      },
      {
        "Modificación": "Ultraligero (Ultra-Light)",
        "Descripción/Características": "No puede montar blindaje mejor que un BAR de 5 debido a una estructura más ligera."
      },
      {
        "Modificación": "VSTOL",
        "Descripción/Características": "Puede operar como un STOL o puede despegar y aterrizar verticalmente."
      }
    ]
  }
