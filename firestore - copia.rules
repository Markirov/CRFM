rules_version = '2';

// ═══════════════════════════════════════════════════════════════
// CRFM — Firestore Security Rules v2
// Acceso por roles via Custom Claims (role: 'admin' | 'dm' | 'pj').
// Asignar con: npx tsx scripts/set-role.ts email@x.com admin|dm|pj
// ═══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function role()       { return request.auth.token.role; }
    function isAdmin()    { return role() == 'admin'; }
    function isDM()       { return role() == 'dm'; }
    function isPJ()       { return role() == 'pj'; }
    function isStaff()    { return isAdmin() || isDM(); }
    function hasAnyRole() { return isAdmin() || isDM() || isPJ(); }

    // ── Config campaña: solo admin ────────────────────────────
    match /config/{doc} {
      allow read:  if isStaff();
      allow write: if isAdmin();
    }

    // ── Libro Mayor / Finanzas: admin R+W, DM solo R ─────────
    match /libroMayor/{doc} {
      allow read:  if isStaff();
      allow write: if isAdmin();
    }

    // ── Personajes / Barracones ───────────────────────────────
    // Todos leen. Staff escribe cualquiera.
    // PJ escribe solo su propio doc (match por email en el doc).
    match /personajes/{name} {
      allow read:  if hasAnyRole();
      allow write: if isStaff()
                   || (isPJ() && request.auth.token.email == resource.data.email);
    }

    // ── Hoja de Servicio: staff R+W, PJ solo R ───────────────
    match /hojaServicio/{doc} {
      allow read:  if hasAnyRole();
      allow write: if isStaff();
    }

    // ── Crónicas: staff R+W, PJ solo R ───────────────────────
    match /cronicas/{doc} {
      allow read:  if hasAnyRole();
      allow write: if isStaff();
    }

    // ── Hangar: staff R+W, PJ solo R ─────────────────────────
    match /hangar/{doc} {
      allow read:  if hasAnyRole();
      allow write: if isStaff();
    }

    // ── Fuerzas / Simulador: todos R+W ───────────────────────
    match /fuerzas/{doc} {
      allow read, write: if hasAnyRole();
    }

    // ── Resto (parteDiario, logros, movimientos, etc.) ────────
    // Staff R+W, PJ solo R.
    match /{collection}/{doc} {
      allow read:  if hasAnyRole();
      allow write: if isStaff();
    }
  }
}
