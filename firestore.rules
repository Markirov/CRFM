rules_version = '2';

// ═══════════════════════════════════════════════════════════════
// CRFM — Firestore Security Rules
//
// MODO DEV (actual): acceso abierto con caducidad.
// Cambiar fecha o cerrar acceso cuando metamos Firebase Auth.
//
// Para producción:
//   - allow read: if request.auth != null;
//   - allow write: if request.auth.token.admin == true; (custom claim)
// ═══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // Acceso abierto temporal hasta 2026-12-31.
    // Una vez vencido, todas las requests fallan hasta que actualices reglas.
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 12, 31);
    }
  }
}
