rules_version = '2';

// ═══════════════════════════════════════════════════════════════
// CRFM — Firestore Security Rules v2 (Unificadas)
// Acceso por roles (admin | dm | pj) + Correos fundadores
// ═══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────

    function isHardcodedAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'marcosfenollar@gmail.com';
    }

    function claimRole() {
      return (request.auth != null && 'role' in request.auth.token) ? request.auth.token.role : null;
    }

    function isAdmin()    { return isHardcodedAdmin() || claimRole() == 'admin'; }
    function isDM()       { return claimRole() == 'dm'; }
    function isPJ()       { return claimRole() == 'pj'; }
    function isStaff()    { return isAdmin() || isDM(); }
    function hasAnyRole() { return isAdmin() || isDM() || isPJ(); }
    function isAuthenticated() { return request.auth != null; }

    function isLiveRoomId(roomId) {
      return roomId == 'alpha' || roomId == 'beta' || roomId == 'delta';
    }

    function liveRoom(roomId) {
      return get(/databases/$(database)/documents/live_rooms/$(roomId));
    }

    function isActiveLiveRoom(roomId) {
      return isLiveRoomId(roomId)
        && liveRoom(roomId).data.status == 'active'
        && liveRoom(roomId).data.expiresAt is timestamp
        && liveRoom(roomId).data.expiresAt > request.time;
    }

    function isLiveParticipant(roomId) {
      return isAuthenticated()
        && isActiveLiveRoom(roomId)
        && exists(/databases/$(database)/documents/live_rooms/$(roomId)/sessions/$(request.auth.uid))
        && get(/databases/$(database)/documents/live_rooms/$(roomId)/sessions/$(request.auth.uid)).data.generation
          == liveRoom(roomId).data.generation;
    }

    // ── Permisos UI (matriz editable desde SecretMenu) ────────
    // PJ y DM leen para que la app aplique readOnly en tiempo real.
    // Solo admin escribe.
    match /config/permisos {
      allow read:  if hasAnyRole();
      allow write: if isAdmin();
    }

    // ── Config split: main (admin) vs sim (PJ writable) ──────
    //
    // config/main = datos sensibles administración (CONTRATO_VALOR,
    // AÑO/MES, prompts IA, public_roles). Cualquier rol lee, solo
    // admin escribe.
    //
    // config/sim = datos de combate (FUERZA_*, ENEMIGO*, ESTADOMECHS,
    // PILOTO_*_MECH). Cualquier rol con sesión puede leer/escribir
    // porque flujo simulador (PJ) y HUD (DM) lo requieren.
    //
    // Cualquier otro doc bajo config/ está implícitamente denegado
    // (Firestore closed-by-default) — añadir match explícito si hace falta.
    match /config/main {
      allow read:  if hasAnyRole();
      allow write: if isAdmin();
    }
    match /config/sim {
      allow read, write: if hasAnyRole();
    }

    match /noticias/{noticiaId} {
      allow read:  if hasAnyRole();
      allow write: if isAdmin();
    }

    match /enciclopedia/{document=**} {
      allow read: if true;
    }

    // ── Libro Mayor / Finanzas: admin R+W, DM solo R ─────────
    match /libroMayor/{doc} {
      allow read:  if isStaff();
      allow write: if isAdmin();
    }

    // ── Personajes / Barracones ───────────────────────────────
    match /personajes/{name} {
      allow read:  if hasAnyRole();
      allow write: if isStaff()
                   || (isPJ() && request.auth.token.email == resource.data.email);
    }

    // ── Hoja de Servicio: staff R+W, PJ solo R ───────────────
    match /hojaServicio/{doc} {
      allow read:  if hasAnyRole();
      allow write: if isStaff();
    }

    // ── Cronicas: staff R+W, PJ solo R ───────────────────────
    match /cronicas/{doc} {
      allow read:  if hasAnyRole();
      allow write: if isStaff();
    }

    // ── Hangar: staff R+W, PJ solo R ─────────────────────────
    match /hangar/{doc} {
      allow read:  if hasAnyRole();
      allow write: if isStaff();
    }

    // ── Recruitment requests: cualquier autenticado crea,
    //    autor + staff leen, solo staff actualiza/borra ─────────
    match /recruitmentPending/{id} {
      allow create: if isAuthenticated()
                    && request.resource.data.createdByEmail is string
                    && request.resource.data.status == 'pending';
      allow read:   if isStaff()
                    || (isAuthenticated()
                        && resource.data.createdByEmail == request.auth.token.email);
      allow update, delete: if isStaff();
    }

    // ── Roles: admin escribe, autenticados leen (para AuthGate) ──
    match /roles/{doc} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ── User Prefs: cada usuario lee/escribe SOLO sus propias prefs ──
    // Path: users/{uid}/prefs/{prefDoc}. Ej: users/abc123/prefs/autoroll
    match /users/{uid}/prefs/{prefDoc} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Fuerzas / Simulador: todos R+W ───────────────────────
    match /fuerzas/{doc} {
      allow read, write: if hasAnyRole();
    }

    // ── Live Rooms (Alpha / Beta / Delta) ───────────────────
    // Todas las escrituras pasan por Cloud Functions. El cliente
    // solo puede leer el estado de las tres salas y, tras unirse,
    // las sesiones/ataques de su sala activa.
    match /live_rooms/{roomId} {
      allow get: if isAuthenticated() && isLiveRoomId(roomId);
      allow list, create, update, delete: if false;

      match /sessions/{sessionUid} {
        allow read: if isLiveParticipant(roomId);
        allow write: if false;
      }

      match /attacks/{attackId} {
        allow read: if isLiveParticipant(roomId);
        allow write: if false;
      }
    }

    // Colección legacy cerrada. Se conserva temporalmente para que
    // una migración coordinada no reutilice accidentalmente sus datos.
    match /live_sessions/{doc} {
      allow read, write: if false;
    }

    // ── Colecciones varias: staff R+W, PJ solo R ─────────────
    // (cada una explícita para que el catch-all no fugue write en
    // docs específicos como config/main)
    match /personal/{doc} {
      allow read:  if hasAnyRole();
      allow write: if isStaff();
    }
    match /historial/{doc} {
      allow read:  if hasAnyRole();
      allow write: if isStaff();
    }
    match /logros/{doc} {
      allow read:  if hasAnyRole();
      allow write: if isStaff();
    }
    match /mejoras/{doc} {
      allow read:  if hasAnyRole();
      allow write: if isStaff();
    }
    match /gastosXP/{doc} {
      allow read:  if hasAnyRole();
      allow write: if isStaff();
    }
    match /ordenDia/{doc} {
      allow read:  if hasAnyRole();
      allow write: if isStaff();
    }
    match /parteDiario/{doc} {
      allow read:  if hasAnyRole();
      allow write: if isStaff();
    }

    // Cualquier doc no listado → denied (closed-by-default).
  }
}
